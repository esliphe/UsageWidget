{
  "manifest_version": 3,
  "name": "UsageWidget URL Bridge",
  "version": "1.1.1",
  "description": "Send active tab, page signals, and audible media state to the local UsageWidget desktop app.",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["http://127.0.0.1:47621/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "UsageWidget URL Bridge"
  }
}
